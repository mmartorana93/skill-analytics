cache.json
cache.json.tmp

# Live-refresh marker written by the PostToolUse hook (holds a real cwd/session).
live-signal

# Advisor verdict cache — holds verbatim user-prompt snippets. Data artifact.
advisor-cache.json
advisor-cache.json.tmp

# PM2 runtime logs
pm2-out.log
pm2-error.log

# Python
__pycache__/
*.pyc
